<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                        https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Entity\Avaliacao\Avaliacao" table="avaliacoes" schema="avaliacao" repository-class="App\Repository\Avaliacao\AvaliacaoRepository">

        <id name="servico" association-key="true" />

        <field name="nota" type="float" column="nota" />

        <field name="comentario" type="text" column="comentario" nullable="true" />

        <one-to-one field="servico" target-entity="App\Entity\Servico\Servico">
            <join-column name="id_servico" referenced-column-name="id" nullable="false" />
        </one-to-one>

        <one-to-many field="imagens" target-entity="App\Entity\Avaliacao\Imagem" mapped-by="avaliacao">
            <cascade>
                <cascade-persist/>
            </cascade>
        </one-to-many>

    </entity>
</doctrine-mapping>