<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Entity\Localizacao\Cep" table="cep" schema="localizacao">

        <id name="numero" type="string" length="9" column="numero" />

        <field name="rua" type="string" length="255" column="rua" nullable="false" />

        <field name="bairro" type="string" length="255" column="bairro" nullable="false" />

        <many-to-one field="municipio" target-entity="App\Entity\Localizacao\Municipio" inversed-by="ceps">
            <join-column name="id_municipio" referenced-column-name="id" nullable="false" />
        </many-to-one>

    </entity>
</doctrine-mapping>