<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Entity\Empresarial\EmpresaPrestador" table="empresa_prestadores" schema="empresarial" repository-class="App\Repository\Empresarial\EmpresaPrestadorRepository">

        <id name="idPrestador" type="uuid" column="id_prestador" />

        <many-to-one field="empresa" target-entity="App\Entity\Empresarial\Empresa" inversed-by="prestadores">
            <join-column name="id_empresa" referenced-column-name="id" nullable="false" />
        </many-to-one>

        <field name="criadoEm" type="datetime_immutable" column="criado_em" />
        <field name="excluidoEm" type="datetime_immutable" column="excluido_em" nullable="true" />

    </entity>
</doctrine-mapping>