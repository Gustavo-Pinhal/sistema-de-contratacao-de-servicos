<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Entity\Servico\Cliente" 
            table="clientes" 
            schema="auth" 
            repository-class="App\Repository\Servico\ClienteRepository">

        <id name="id" type="uuid" column="id" />

        <field name="nome" type="string" length="255" nullable="false" />
        <field name="criadoEm" type="datetime_immutable" column="criado_em" />
        <field name="excluidoEm" type="datetime_immutable" column="excluido_em" nullable="true" />

        <one-to-one field="usuario" target-entity="App\Entity\Auth\Usuario">
            <join-column name="id_usuario" referenced-column-name="id" unique="true" nullable="false" />
        </one-to-one>

    </entity>
</doctrine-mapping>